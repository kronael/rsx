def select_symbols(count, override_list=None):
    """Pick symbols by count from SYMBOL_ORDER."""
    if override_list:
        names = [s.strip().upper()
                 for s in override_list.split(",")]
        return [SYMBOLS[n] | {"name": n} for n in names
                if n in SYMBOLS]
    return [SYMBOLS[n] | {"name": n}
            for n in SYMBOL_ORDER[:count]]


def resolve_scenario(args):
    """Resolve CLI args into spawn config dict (CLI overrides win)."""
    scenario = args.scenario or "minimal"
    preset = SCENARIOS.get(scenario)
    if not preset:
        print(f"unknown scenario: {scenario}")
        print(f"known: {', '.join(SCENARIOS)}")
        sys.exit(1)

    # CLI args override preset
    symbols = select_symbols(
        preset["symbols"],
        args.symbols,
    )
    gateways = (args.gateways if args.gateways is not None
                else preset["gateways"])
    replication = (args.replication if args.replication is not None
                   else preset["replication"])
    risk_shards = (args.risk_shards if args.risk_shards is not None
                   else 1)

    return {
        "symbols": symbols,
        "gateways": int(gateways),
        "risk_shards": int(risk_shards),
        "replication": replication,
    }


def build_spawn_plan(config, pg_url, release=False):
    """Build ordered list of (name, binary, env) tuples."""
    plan = []
    symbols = config["symbols"]
    replication = config["replication"]

    target = "./target/release" if release else "./target/debug"

    # symbol map for mark: "PENGU=10,SOL=3,..."
    mark_symbol_map = ",".join(
        f"{s['name']}={s['id']}" for s in symbols
    )

    # ── ME instances ────────────────────────────────
    for sym in symbols:
        sid = sym["id"]
        me_cmp = f"127.0.0.1:{BASE_ME_CMP + sid}"
        risk_cmp = f"127.0.0.1:{BASE_RISK_CMP}"
        md_cmp = f"127.0.0.1:{BASE_MD_CMP + sid}"
        env = {
            "RSX_ME_SYMBOL_ID": str(sid),
            "RSX_ME_PRICE_DECIMALS": str(sym["price_dec"]),
            "RSX_ME_QTY_DECIMALS": str(sym["qty_dec"]),
            "RSX_ME_TICK_SIZE": str(sym["tick"]),
            "RSX_ME_LOT_SIZE": str(sym["lot"]),
            "RSX_ME_WAL_DIR": f"./tmp/wal/{sym['name'].lower()}",
            "RSX_ME_CMP_ADDR": me_cmp,
            "RSX_RISK_CMP_ADDR": risk_cmp,
            "RSX_MD_CMP_ADDR": md_cmp,
            "RSX_ME_DATABASE_URL": pg_url,
            "RUST_LOG": "info",
        }
        plan.append((
            f"me-{sym['name'].lower()}",
            f"{target}/rsx-matching",
            env,
        ))

    # ── Mark aggregator ─────────────────────────────
    plan.append((
        "mark",
        f"{target}/rsx-mark",
        {
            "RSX_MARK_LISTEN_ADDR":
                f"127.0.0.1:{BASE_MARK_CMP}",
            "RSX_MARK_WAL_DIR": "./tmp/wal/mark",
            "RSX_MARK_STREAM_ID": "100",
            "RSX_MARK_SYMBOL_MAP": mark_symbol_map,
            "RSX_RISK_MARK_CMP_ADDR":
                f"127.0.0.1:{BASE_RISK_MARK_CMP}",
            "RUST_LOG": "info",
        },
    ))

    # ── Risk engine ─────────────────────────────────
    for shard in range(config["risk_shards"]):
        # primary
        plan.append((
            f"risk-{shard}",
            f"{target}/rsx-risk",
            {
                "RSX_RISK_SHARD_ID": str(shard),
                "RSX_RISK_SHARD_COUNT":
                    str(config["risk_shards"]),
                "RSX_RISK_MAX_SYMBOLS": str(max(s["id"] for s in symbols) + 1),
                "RSX_RISK_CMP_ADDR":
                    f"127.0.0.1:{BASE_RISK_CMP + shard}",
                "RSX_GW_CMP_ADDR":
                    f"127.0.0.1:{BASE_GW_CMP}",
                "RSX_ME_CMP_ADDR":
                    f"127.0.0.1:{BASE_ME_CMP + symbols[0]['id']}",
                "RSX_RISK_WAL_DIR": "./tmp/wal",
                "RSX_RISK_MARK_CMP_ADDR":
                    f"127.0.0.1:{BASE_RISK_MARK_CMP}",
                "RSX_MARK_CMP_ADDR":
                    f"127.0.0.1:{BASE_MARK_CMP}",
                "DATABASE_URL": pg_url,
                "RUST_LOG": "info",
            },
        ))

        # replicas
        if replication in ("replica", "spare"):
            replica_count = 2 if replication == "spare" else 1
            for r in range(replica_count):
                plan.append((
                    f"risk-{shard}-replica-{r}",
                    f"{target}/rsx-risk",
                    {
                        "RSX_RISK_SHARD_ID": str(shard),
                        "RSX_RISK_SHARD_COUNT":
                            str(config["risk_shards"]),
                        "RSX_RISK_MAX_SYMBOLS":
                            str(len(symbols)),
                        "RSX_RISK_IS_REPLICA": "true",
                        "RSX_RISK_CMP_ADDR":
                            f"127.0.0.1:{BASE_RISK_CMP + 10 + shard * 2 + r}",
                        "RSX_GW_CMP_ADDR":
                            f"127.0.0.1:{BASE_GW_CMP}",
                        "RSX_ME_CMP_ADDR":
                            f"127.0.0.1:{BASE_ME_CMP + symbols[0]['id']}",
                        "RSX_RISK_WAL_DIR": "./tmp/wal",
                        "DATABASE_URL": pg_url,
                        "RUST_LOG": "info",
                    },
                ))

    # ── Gateway(s) ──────────────────────────────────
    for gw in range(config["gateways"]):
        # per-symbol tick/lot env vars for gateway
        sym_env = {}
        for sym in symbols:
            sid = sym["id"]
            sym_env[f"RSX_SYMBOL_{sid}_TICK_SIZE"] = str(
                sym["tick"]
            )
            sym_env[f"RSX_SYMBOL_{sid}_LOT_SIZE"] = str(
                sym["lot"]
            )
        plan.append((
            f"gw-{gw}",
            f"{target}/rsx-gateway",
            {
                "RSX_GW_LISTEN":
                    f"0.0.0.0:{BASE_GW_WS + gw}",
                "RSX_GW_CMP_ADDR":
                    f"127.0.0.1:{BASE_GW_CMP + gw}",
                "RSX_RISK_CMP_ADDR":
                    f"127.0.0.1:{BASE_RISK_CMP}",
                "RSX_GW_WAL_DIR": "./tmp/wal",
                "RSX_GW_JWT_SECRET": "",
                "RSX_MAX_SYMBOLS": "16",
                **sym_env,
                "RUST_LOG": "info",
            },
        ))

    # ── Marketdata ──────────────────────────────────
    plan.append((
        "marketdata",
        f"{target}/rsx-marketdata",
        {
            "RSX_MD_LISTEN":
                f"0.0.0.0:{BASE_MD_WS}",
            "RSX_MKT_CMP_ADDR":
                f"127.0.0.1:{BASE_MD_CMP + symbols[0]['id']}",
            "RSX_ME_CMP_ADDR":
                f"127.0.0.1:{BASE_ME_CMP + symbols[0]['id']}",
            "RSX_MD_STREAM_ID": "1",
            "RUST_LOG": "info",
        },
    ))

    return plan


def print_plan(plan):
    """Print spawn plan without running."""
    print("spawn plan:")
    print(f"  {'name':<24} {'binary':<36} env vars")
    print("  " + "-" * 72)
    for name, binary, env in plan:
        short_bin = binary.split("/")[-1]
        env_summary = " ".join(
            f"{k}={v}" for k, v in sorted(env.items())
            if k != "RUST_LOG"
        )
        # truncate env summary for display
        if len(env_summary) > 80:
            env_summary = env_summary[:77] + "..."
        print(f"  {name:<24} {short_bin:<36} {env_summary}")
    print(f"\n  total: {len(plan)} processes")


# ── async process management ────────────────────────────

PROCS = {}  # name -> asyncio.Process
PLAN = {}   # name -> (binary, env)


async def pipe_output(name, stream):
    """Read process stdout and print with prefix."""
    prefix = f"[{name}]"
    while True:
        line = await stream.readline()
        if not line:
            break
        text = line.decode("utf-8", errors="replace")
        print(f"{prefix} {text}", end="", flush=True)


async def spawn(name, binary, env):
    """Spawn a process as an asyncio task."""
    full_env = {**os.environ, **env}
    proc = await asyncio.create_subprocess_exec(
        binary,
        env=full_env,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
    )
    PROCS[name] = proc
    PLAN[name] = (binary, env)
    asyncio.create_task(pipe_output(name, proc.stdout))
    return proc


async def stop_proc(name):
    """Stop a single process by name."""
    proc = PROCS.get(name)
    if not proc or proc.returncode is not None:
        print(f"  {name} not running")
        return
    proc.terminate()
    try:
        await asyncio.wait_for(
            proc.wait(), timeout=5.0,
        )
        print(f"  {name} stopped")
    except asyncio.TimeoutError:
        proc.kill()
        print(f"  {name} killed")


async def start_proc(name):
    """Start (or restart) a process by name."""
    if name not in PLAN:
        print(f"  unknown: {name}")
        return
    proc = PROCS.get(name)
    if proc and proc.returncode is None:
        print(f"  {name} already running")
        return
    binary, env = PLAN[name]
    await spawn(name, binary, env)
    print(f"  {name} started")


async def shutdown_all():
    """SIGTERM all children and wait."""
    print("\nshutting down...")
    for name, proc in PROCS.items():
        if proc.returncode is None:
            proc.terminate()
    for name, proc in PROCS.items():
        try:
            await asyncio.wait_for(
                proc.wait(), timeout=5.0,
            )
        except asyncio.TimeoutError:
            print(f"  killing {name}")
            proc.kill()
    print("all processes stopped")


import shutil


def clean_tmp():
    """Wipe ./tmp (WAL, snapshots, tips)."""
    if os.path.exists("./tmp"):
        shutil.rmtree("./tmp")
        print("cleaned ./tmp")


def reset_db(pg_url):
    """Drop and recreate rsx database."""
    # parse db name from URL
    # postgres://user:pass@host:port/dbname
    db_name = pg_url.rsplit("/", 1)[-1]
    if not db_name.isidentifier():
        print(f"error: invalid database name: {db_name}")
        return
    quoted_name = f'"{db_name}"'
    base_url = pg_url.rsplit("/", 1)[0] + "/postgres"
    result = subprocess.run(
        ["psql", base_url, "-c",
         f"DROP DATABASE IF EXISTS {quoted_name}"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"drop db warning: {result.stderr.strip()}")
    result = subprocess.run(
        ["psql", base_url, "-c",
         f"CREATE DATABASE {quoted_name}"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"create db error: {result.stderr.strip()}")
    else:
        print(f"reset database {db_name}")


def ensure_dirs(symbols):
    """Create required directories."""
    dirs = [
        "./tmp/wal/mark",
        "./tmp/snapshot",
        "./log",
    ]
    for sym in symbols:
        dirs.append(
            f"./tmp/wal/{sym['name'].lower()}"
        )
    for d in dirs:
        os.makedirs(d, exist_ok=True)


def ensure_postgres_docker(pg_url):
    """Start or reuse a named Postgres container."""
    # check if container exists and is running
    result = subprocess.run(
        ["docker", "inspect", "-f",
         "{{.State.Running}}", PG_CONTAINER],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        if "true" in result.stdout:
            print(f"reusing postgres container {PG_CONTAINER}")
            return
        # exists but stopped, start it
        subprocess.run(
            ["docker", "start", PG_CONTAINER],
            check=True,
        )
        print(f"started existing postgres "
              f"container {PG_CONTAINER}")
        time.sleep(2)
        return

    # create new container
    print(f"creating postgres container {PG_CONTAINER}")
    subprocess.run([
        "docker", "run", "-d",
        "--name", PG_CONTAINER,
        "-e", "POSTGRES_USER=rsx",
        "-e", "POSTGRES_PASSWORD=rsx",
        "-e", "POSTGRES_DB=rsx",
        "-p", "5432:5432",
        "postgres:16-alpine",
    ], check=True)
    # wait for postgres to be ready
    print("waiting for postgres...")
    for _ in range(30):
        time.sleep(1)
        r = subprocess.run(
            ["docker", "exec", PG_CONTAINER,
             "pg_isready", "-U", "rsx"],
            capture_output=True,
        )
        if r.returncode == 0:
            print("postgres ready")
            return
    print("error: postgres did not become ready")
    sys.exit(1)


def run_migration(pg_url):
    """Run SQL migration via psql."""
    migration = os.path.join(
        os.path.dirname(__file__),
        "rsx-risk/migrations/001_base_schema.sql",
    )
    if not os.path.exists(migration):
        print(f"warning: migration not found: {migration}")
        return
    result = subprocess.run(
        ["psql", pg_url, "-f", migration],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"migration warning: {result.stderr.strip()}")
    else:
        print("migration applied")


# ── main ────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        description="RSX local dev runner",
    )
    parser.add_argument(
        "scenario", nargs="?", default="minimal",
        help="scenario name or code (default: minimal)",
    )
    parser.add_argument(
        "-p", "--postgres", default="external",
        choices=["docker", "external"],
        help="postgres mode (default: external)",
    )
    parser.add_argument(
        "--pg-url", default=DEFAULT_PG_URL,
    )
    parser.add_argument(
        "-n", "--no-build", action="store_true",
        help="skip cargo build",
    )
    parser.add_argument(
        "-r", "--release", action="store_true",
        help="build in release mode",
    )
    parser.add_argument(
        "-d", "--dry-run", action="store_true",
        help="print spawn plan without running",
    )
    parser.add_argument(
        "-s", "--symbols", default=None,
    )
    parser.add_argument(
        "-g", "--gateways", type=int, default=None,
    )
    parser.add_argument(
        "--risk-shards", type=int, default=None,
    )
    parser.add_argument(
        "--replication", default=None,
        choices=["none", "replica", "spare"],
    )
    parser.add_argument(
        "-c", "--clean", action="store_true",
        help="wipe ./tmp before starting",
    )
    parser.add_argument(
        "--reset-db", action="store_true",
        help="drop and recreate rsx database",
    )

    args = parser.parse_args()
    config = resolve_scenario(args)
    plan = build_spawn_plan(config, args.pg_url, args.release)

    if args.dry_run:
        print_plan(plan)
        return

    # cleanup
    if args.clean:
        clean_tmp()
    if args.reset_db:
        reset_db(args.pg_url)

    # build (default: yes, skip with --no-build)
    if not args.no_build:
        cmd = ["cargo", "build"]
        if args.release:
            cmd.append("--release")
        print(f"building: {' '.join(cmd)}")
        result = subprocess.run(cmd)
        if result.returncode != 0:
            print("build failed")
            sys.exit(1)

    # dirs
    ensure_dirs(config["symbols"])

    # postgres
    if args.postgres == "docker":
        ensure_postgres_docker(args.pg_url)

    # wait for postgres to be ready
    pg_host = args.pg_url.split("@")[-1].split("/")[0] if "@" in args.pg_url else "localhost:5432"
    for attempt in range(10):
        r = subprocess.run(
            ["pg_isready", "-d", args.pg_url],
            capture_output=True, text=True,
        )
        if r.returncode == 0:
            break
        if attempt == 9:
            print("error: postgres not ready after 10 retries")
            sys.exit(1)
        print(f"waiting for postgres... (attempt {attempt + 1}/10)")
        time.sleep(1)

    # migration
    run_migration(args.pg_url)

    # spawn
    print_plan(plan)
    print()
    asyncio.run(run_all(plan))


REPL_HELP = """\
commands:
  status          show all processes
  stop <name>     stop a process
  start <name>    start/restart a process
  kill <name>     SIGKILL a process
  restart <name>  stop then start
  quit            shutdown all and exit
  help            show this message
"""


async def repl():
    """Interactive control loop."""
    reader = asyncio.StreamReader()
    protocol = asyncio.StreamReaderProtocol(reader)
    await asyncio.get_event_loop().connect_read_pipe(
        lambda: protocol, sys.stdin,
    )
    print(REPL_HELP)
    sys.stdout.write("rsx> ")
    sys.stdout.flush()
    while True:
        line = await reader.readline()
        if not line:
            break
        cmd = line.decode().strip()
        if not cmd:
            pass
        elif cmd == "help":
            print(REPL_HELP)
        elif cmd == "status":
            print_status()
        elif cmd.startswith("stop "):
            parts = cmd.split(None, 1)
            if len(parts) < 2:
                print("  usage: stop <name>")
            else:
                await stop_proc(parts[1])
        elif cmd.startswith("start "):
            parts = cmd.split(None, 1)
            if len(parts) < 2:
                print("  usage: start <name>")
            else:
                await start_proc(parts[1])
        elif cmd.startswith("kill "):
            parts = cmd.split(None, 1)
            if len(parts) < 2:
                print("  usage: kill <name>")
            else:
                name = parts[1]
                proc = PROCS.get(name)
                if proc and proc.returncode is None:
                    proc.kill()
                    print(f"  {name} killed")
                else:
                    print(f"  {name} not running")
        elif cmd.startswith("restart "):
            parts = cmd.split(None, 1)
            if len(parts) < 2:
                print("  usage: restart <name>")
                sys.stdout.write("rsx> ")
                sys.stdout.flush()
                continue
            name = parts[1]
            await stop_proc(name)
            await start_proc(name)
        elif cmd in ("quit", "exit", "q"):
            return
        else:
            print(f"  unknown: {cmd}")
        sys.stdout.write("rsx> ")
        sys.stdout.flush()


def print_status():
    """Print status of all processes."""
    for name in PLAN:
        proc = PROCS.get(name)
        if not proc:
            state = "not started"
        elif proc.returncode is None:
            state = f"running (pid {proc.pid})"
        else:
            state = f"exited ({proc.returncode})"
        print(f"  {name:<24} {state}")


async def watch_exits():
    """Background task: report child exits."""
    seen = set()
    while True:
        for name, proc in PROCS.items():
            if proc.returncode is not None \
                    and name not in seen:
                seen.add(name)
                print(
                    f"\n  {name} exited "
                    f"with {proc.returncode}"
                )
                sys.stdout.write("rsx> ")
                sys.stdout.flush()
        await asyncio.sleep(1)


async def run_all(plan):
    """Spawn all processes, then enter REPL."""
    loop = asyncio.get_event_loop()
    stopping = False

    def handle_signal():
        nonlocal stopping
        if not stopping:
            stopping = True
            asyncio.create_task(graceful_exit())

    loop.add_signal_handler(
        signal.SIGINT, handle_signal,
    )
    loop.add_signal_handler(
        signal.SIGTERM, handle_signal,
    )

    for name, binary, env in plan:
        if not os.path.exists(binary):
            print(f"error: not found: {binary}")
            print("binary not found, build first")
            await shutdown_all()
            sys.exit(1)
        print(f"  starting {name}...")
        await spawn(name, binary, env)
        await asyncio.sleep(0.1)

    print(
        f"\n{len(PROCS)} processes running. "
        f"type 'help' for commands.\n"
    )

    # background watcher + interactive repl
    watcher = asyncio.create_task(watch_exits())
    await repl()
    watcher.cancel()
    await graceful_exit()


async def graceful_exit():
    """Handle SIGINT/SIGTERM gracefully."""
    await shutdown_all()
    print("\nexit summary:")
    for name, proc in PROCS.items():
        code = proc.returncode or 0
        status = "ok" if code == 0 else f"exit {code}"
        print(f"  {name}: {status}")
    sys.exit(0)


if __name__ == "__main__":
    main()
