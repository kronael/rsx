#!/usr/bin/env python3
"""Playground CLI - manage RSX playground server and processes.

Server lifecycle:
    start              Start server in background
    stop               Stop server gracefully
    restart            Restart server
    status             Check server status

Process management:
    demo [scenario]        Start server + E2E RSX demo
    plan [scenario]        Print the scenario spawn plan
    start-all [scenario]   Build and start all RSX processes
    stop-all               Stop all RSX processes
    ps                     List all processes
    start-proc <name>      Start individual process
    stop-proc <name>       Stop individual process
    restart-proc <name>    Restart individual process

Orders:
    submit-order [args]    Submit test order
    batch-orders           Submit batch of orders
    stress [rate] [dur]    Run stress test

Info:
    logs [--follow]        View logs
    scenarios              List available scenarios
    health                 Health check (server + processes)
    doctor                 Check local demo prerequisites

Utils:
    reset                  Stop all and clean state
"""

import sys
import subprocess
import signal
import time
import os
import shutil
from pathlib import Path

import runtime

ROOT = Path(__file__).resolve().parent.parent
PID_FILE = ROOT / "tmp" / "pids" / "playground-server.pid"
LOG_FILE = ROOT / "log" / "server.log"
SERVER_PORT = 49171
API_BASE = f"http://localhost:{SERVER_PORT}"

# ── Server lifecycle ────────────────────────────────────


def is_running():
    """Check if server is running via PID file."""
    if not PID_FILE.exists():
        return False
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return True
    except ValueError:
        # invalid PID file
        PID_FILE.unlink(missing_ok=True)
        return False
    except FileNotFoundError:
        # PID file deleted between exists() and read()
        return False
    except ProcessLookupError:
        # process doesn't exist
        PID_FILE.unlink(missing_ok=True)
        return False
    except PermissionError:
        # Could be our process but different user, or different process.
        # Conservative: assume stale and clean up
        try:
            PID_FILE.unlink()
        except OSError:
            pass
        return False
    except OSError:
        # other OS error, assume stale
        PID_FILE.unlink(missing_ok=True)
        return False


def start_server():
    """Start server as detached daemon."""
    if is_running():
        print("server already running")
        return 0

    # check port not in use
    import socket
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        result = sock.connect_ex(("localhost", SERVER_PORT))
        if result == 0:
            print(
                f"error: port {SERVER_PORT} already in use")
            print("check for conflicting process:")
            print(f"  lsof -i:{SERVER_PORT}")
            return 1
    except Exception:
        pass
    finally:
        sock.close()

    # ensure dirs
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)

    # spawn detached daemon. Inject the dev JWT secret if
    # the operator hasn't already set one — keeps the
    # quickstart frictionless while still failing fast for
    # any production deploy that forgets to override.
    env = os.environ.copy()
    env.setdefault(
        "RSX_GW_JWT_SECRET",
        "rsx-dev-secret-not-for-prod-padpad",
    )
    server_script = ROOT / "rsx-playground" / "server.py"
    with open(LOG_FILE, "a") as log:
        proc = subprocess.Popen(
            ["uv", "run", str(server_script)],
            cwd=str(ROOT / "rsx-playground"),
            stdout=log,
            stderr=log,
            start_new_session=True,
            env=env,
        )
    PID_FILE.write_text(str(proc.pid))
    print(f"server started (pid {proc.pid})")
    print(f"visit http://localhost:{SERVER_PORT}")
    return 0


def stop_server():
    """Stop server gracefully."""
    if not is_running():
        print("server not running")
        return 0

    pid = int(PID_FILE.read_text().strip())
    print(f"stopping server (pid {pid})...")
    try:
        os.kill(pid, signal.SIGTERM)
        for _ in range(50):
            time.sleep(0.1)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                break
        else:
            print("timeout, killing...")
            os.kill(pid, signal.SIGKILL)
        PID_FILE.unlink(missing_ok=True)
        print("server stopped")
    except ProcessLookupError:
        if PID_FILE.exists():
            PID_FILE.unlink(missing_ok=True)
        print("server already stopped")
    return 0


def status_server():
    """Check server status."""
    if is_running():
        pid = int(PID_FILE.read_text().strip())
        print(f"server running (pid {pid})")
        print(f"visit http://localhost:{SERVER_PORT}")
        return 0
    else:
        print("server not running")
        return 1


# ── API helpers ─────────────────────────────────────────


def ensure_server():
    """Ensure server is running, start if needed."""
    if not is_running():
        print("server not running, starting...")
        result = start_server()
        if result != 0:
            return False
        # wait for server to be ready
        try:
            import httpx
        except ImportError:
            time.sleep(2)
            return True
        for _ in range(20):
            time.sleep(0.2)
            try:
                resp = httpx.get(
                    f"{API_BASE}/healthz", timeout=1)
                if resp.status_code == 200:
                    return True
            except Exception:
                continue
        print("warning: server started but health check failed")
        print(f"check logs: {LOG_FILE}")
        return False
    return True


def api_get(path):
    """GET request to server API."""
    try:
        import httpx
    except ImportError:
        print("error: httpx not installed")
        print("run: uv pip install httpx")
        return None
    if not ensure_server():
        return None
    try:
        resp = httpx.get(f"{API_BASE}{path}", timeout=15)
        resp.raise_for_status()
        return resp.json()
    except httpx.ConnectError:
        print(f"error: cannot connect to {API_BASE}")
        print("is server running? check: ./playground status")
        return None
    except httpx.TimeoutException:
        print(f"error: request to {path} timed out")
        return None
    except httpx.HTTPStatusError as e:
        print(f"error: {e.response.status_code} from {path}")
        return None
    except Exception as e:
        print(f"error: unexpected failure: {e}")
        return None


def api_post(path, data=None, headers=None, timeout=120):
    """POST request to server API."""
    try:
        import httpx
    except ImportError:
        print("error: httpx not installed")
        print("run: uv pip install httpx")
        return None
    if not ensure_server():
        return None
    try:
        resp = httpx.post(
            f"{API_BASE}{path}",
            json=data or {},
            headers=headers or {},
            timeout=timeout,
        )
        resp.raise_for_status()
        return resp.status_code == 200
    except httpx.ConnectError:
        print(f"error: cannot connect to {API_BASE}")
        print("is server running? check: ./playground status")
        return None
    except httpx.TimeoutException:
        print(f"error: request to {path} timed out")
        return None
    except httpx.HTTPStatusError as e:
        print(f"error: {e.response.status_code} from {path}")
        return None
    except Exception as e:
        print(f"error: unexpected failure: {e}")
        return None


# ── Process management ──────────────────────────────────


def print_plan(plan):
    """Print a compact scenario plan."""
    print("spawn plan:")
    print(f"  {'name':<20} {'binary':<18} env")
    print("  " + "-" * 60)
    for name, binary, env in plan:
        short_bin = binary.split("/")[-1]
        items = [
            f"{k}={v}" for k, v in sorted(env.items())
            if k != "RUST_LOG"
        ]
        text = " ".join(items)
        if len(text) > 80:
            text = text[:77] + "..."
        print(f"  {name:<20} {short_bin:<18} {text}")
    print(f"\n  total: {len(plan)} processes")


def scenario_plan(scenario="minimal"):
    """Print the plan Playground will deploy."""
    preset = runtime.SCENARIOS.get(scenario)
    if not preset:
        print(f"unknown scenario: {scenario}")
        print(f"known: {', '.join(runtime.SCENARIOS)}")
        return 1
    config = {
        "symbols": runtime.select_symbols(preset["symbols"]),
        "gateways": preset["gateways"],
        "risk_shards": 1,
        "replication": preset["replication"],
    }
    pg_url = os.environ.get("DATABASE_URL", runtime.DEFAULT_PG_URL)
    print_plan(runtime.build_spawn_plan(config, pg_url))
    return 0


def demo(scenario="minimal"):
    """Start the Playground server and E2E RSX demo."""
    if scenario not in runtime.SCENARIOS:
        print(f"unknown scenario: {scenario}")
        print(f"known: {', '.join(runtime.SCENARIOS)}")
        return 1
    if not ensure_server():
        return 1
    rc = start_all(scenario)
    if rc != 0:
        return rc
    if maker("start") != 0:
        return 1
    _wait_live_book()
    print(f"playground: {API_BASE}")
    print("open the Playground to inspect processes, logs, books, and orders")
    return 0


def start_all(scenario="minimal"):
    """Start all processes via API."""
    print(f"starting all processes (scenario: {scenario})...")
    resp = api_post(
        f"/api/processes/all/start?scenario={scenario}",
        headers={"x-confirm": "yes"},
    )
    if not resp:
        print("failed to start processes")
        return 1
    if not _all_expected_processes_running():
        return 1
    print(f"started {scenario} scenario")
    return 0


def _all_expected_processes_running():
    for _ in range(10):
        procs = api_get("/api/processes")
        if procs:
            running = [p for p in procs if p.get("state") == "running"]
            if len(running) == len(procs):
                return True
        time.sleep(0.5)
    if not procs:
        print("failed to verify process status")
        return False
    print(f"partial start: {len(running)}/{len(procs)} processes running")
    return False


def stop_all():
    """Stop all processes via API."""
    print("stopping all processes...")
    resp = api_post(
        "/api/processes/all/stop",
        headers={"x-confirm": "yes"},
    )
    if not resp:
        print("failed to stop processes")
        return 1
    print("stopped all processes")
    return 0


def ps():
    """List all processes."""
    procs = api_get("/api/processes")
    if procs is None:
        print("failed to get process list")
        return 1
    if not procs:
        print("no processes running")
        return 0

    print(
        f"{'NAME':<20} {'PID':<10} {'STATE':<10} "
        f"{'CPU':<8} {'MEM':<10}"
    )
    print("-" * 70)
    for p in procs:
        print(
            f"{p['name']:<20} {str(p['pid']):<10} "
            f"{p['state']:<10} {p.get('cpu', '-'):<8} "
            f"{p.get('mem', '-'):<10}"
        )
    return 0


def start_process(name):
    """Start individual process."""
    print(f"starting {name}...")
    resp = api_post(f"/api/processes/{name}/start")
    if not resp:
        print(f"failed to start {name}")
        return 1
    print(f"started {name}")
    return 0


def stop_process(name):
    """Stop individual process."""
    print(f"stopping {name}...")
    resp = api_post(f"/api/processes/{name}/stop")
    if not resp:
        print(f"failed to stop {name}")
        return 1
    print(f"stopped {name}")
    return 0


def restart_process(name):
    """Restart individual process."""
    print(f"restarting {name}...")
    resp = api_post(f"/api/processes/{name}/restart")
    if not resp:
        print(f"failed to restart {name}")
        return 1
    print(f"restarted {name}")
    return 0


# ── Orders ──────────────────────────────────────────────


def submit_order(
    symbol_id="10",
    side="buy",
    price="50000",
    qty="1.0",
    tif="GTC",
):
    """Submit test order with hardcoded defaults."""
    data = {
        "symbol_id": symbol_id,
        "side": side,
        "price": price,
        "qty": qty,
        "tif": tif,
    }
    resp = api_post("/api/orders/test", data)
    if not resp:
        print("failed to submit order")
        return 1
    print(f"order submitted ({side} {qty} @ {price})")
    return 0


def batch_orders():
    """Submit batch orders."""
    resp = api_post("/api/orders/batch")
    if not resp:
        print("failed to submit batch orders")
        return 1
    print("submitted 10 batch orders")
    return 0


def stress_test(rate=100, duration=60):
    """Run stress test."""
    resp = api_post(
        f"/api/stress/run?rate={rate}&duration={duration}"
    )
    if not resp:
        print("failed to start stress test")
        return 1
    print(
        f"stress test started "
        f"({rate} orders/sec for {duration}s)"
    )
    return 0


def maker(action="start"):
    if action not in ("start", "stop"):
        print("usage: ./playground maker [start|stop]")
        return 1
    resp = api_post(
        f"/api/maker/{action}",
        headers={"x-confirm": "yes"},
        timeout=30,
    )
    if not resp:
        print(f"failed to {action} maker")
        return 1
    print("maker started" if action == "start" else "maker stopped")
    return 0


def _wait_live_book():
    try:
        import httpx
    except ImportError:
        return
    deadline = time.time() + 10
    while time.time() < deadline:
        try:
            html = httpx.get(f"{API_BASE}/x/book-stats", timeout=2).text
            if "no book data yet" not in html:
                print("book live")
                return
        except Exception:
            pass
        time.sleep(0.5)
    print("warning: book not live yet")


# ── Info ────────────────────────────────────────────────


def scenarios():
    """List scenarios."""
    data = api_get("/api/scenarios")
    if data is None:
        print("failed to get scenarios")
        return 1
    if not data:
        print("no scenarios available")
        return 0
    print("available scenarios:")
    for s in data:
        print(f"  - {s}")
    return 0


def health():
    """Health check."""
    # server health
    if not is_running():
        print("server: DOWN")
        return 1

    try:
        import httpx
        resp = httpx.get(f"{API_BASE}/healthz", timeout=2)
        if resp.status_code == 200:
            print("server: ok")
        else:
            print(f"server: error {resp.status_code}")
            return 1
    except ImportError:
        print("server: running (httpx not available)")
    except Exception as e:
        print(f"server: error ({e})")
        return 1

    # process health
    procs = api_get("/api/processes")
    if procs is not None:
        running = [p for p in procs if p["state"] == "running"]
        print(
            f"processes: {len(running)}/{len(procs)} running"
        )

    return 0


def doctor():
    import socket
    from urllib.parse import urlparse

    fail = []
    for cmd_name in ("uv", "python3"):
        if shutil.which(cmd_name) is None:
            fail.append(cmd_name)
    go_bin = os.environ.get("RSX_GO_BIN", "").strip()
    go_ok = go_bin and Path(go_bin).exists()
    go_ok = go_ok or shutil.which("go") is not None
    go_ok = go_ok or Path("/usr/local/go/bin/go").exists()
    if not go_ok:
        fail.append("go")
    bins = [
        "rsx-gateway", "rsx-risk", "rsx-matching",
        "rsx-marketdata", "rsx-mark", "rsx-recorder",
    ]
    missing_bins = [
        b for b in bins if not (ROOT / "target" / "debug" / b).exists()
    ]
    if missing_bins and shutil.which("cargo") is None:
        fail.append("cargo")
    url = urlparse(os.environ.get("DATABASE_URL", runtime.DEFAULT_PG_URL))
    try:
        with socket.create_connection(
            (url.hostname or "127.0.0.1", url.port or 5432),
            timeout=1,
        ):
            pass
    except OSError:
        fail.append("postgres")
    cpus = os.cpu_count() or 0
    if cpus and cpus < 4:
        print(f"WARN cpus={cpus}")
    rmem = Path("/proc/sys/net/core/rmem_max")
    try:
        if rmem.exists() and int(rmem.read_text()) < 26_214_400:
            print("WARN udp_buf")
    except ValueError:
        pass
    if fail:
        print("FAIL " + " ".join(fail))
        return 1
    print("OK doctor")
    return 0


def logs_cmd(follow=False):
    """View logs."""
    if not LOG_FILE.exists():
        print("no logs yet")
        return 1

    try:
        if follow:
            result = subprocess.run(["tail", "-f", str(LOG_FILE)])
        else:
            result = subprocess.run(["tail", "-n", "50", str(LOG_FILE)])
        return result.returncode
    except FileNotFoundError:
        print("error: tail command not found")
        return 1
    except KeyboardInterrupt:
        return 130  # Standard Unix exit code for SIGINT


# ── Utils ───────────────────────────────────────────────


def reset(yes: bool = False):
    """Stop all and clean state."""
    print("warning: this will delete all logs and temp files")
    if not yes:
        if not sys.stdin.isatty():
            print(
                "non-interactive shell: pass --yes to confirm",
                file=sys.stderr,
            )
            return 1
        print("press enter to continue or ctrl-c to cancel...")
        try:
            input()
        except KeyboardInterrupt:
            print("\ncancelled")
            return 1

    print("resetting playground...")
    stop_all()
    time.sleep(1)

    # clean state
    import shutil

    for d in [ROOT / "tmp", ROOT / "log"]:
        if d.exists():
            shutil.rmtree(d)
            print(f"cleaned {d.name}/")

    print("reset complete")
    return 0


# ── Main ────────────────────────────────────────────────


def main():
    """CLI dispatcher."""
    if len(sys.argv) < 2:
        print(__doc__)
        return 0

    cmd = sys.argv[1]

    # server lifecycle
    if cmd == "start":
        return start_server()
    elif cmd == "stop":
        return stop_server()
    elif cmd == "restart":
        result = stop_server()
        if result != 0:
            print("failed to stop server, aborting restart")
            return 1
        time.sleep(1)
        return start_server()
    elif cmd == "status":
        return status_server()

    # process management
    elif cmd in ("demo", "run"):
        scenario = (
            sys.argv[2] if len(sys.argv) > 2 else "minimal"
        )
        return demo(scenario)
    elif cmd == "plan":
        scenario = (
            sys.argv[2] if len(sys.argv) > 2 else "minimal"
        )
        return scenario_plan(scenario)
    elif cmd == "start-all":
        scenario = (
            sys.argv[2] if len(sys.argv) > 2 else "minimal"
        )
        return start_all(scenario)
    elif cmd == "stop-all":
        return stop_all()
    elif cmd == "ps":
        return ps()
    elif cmd == "start-proc":
        if len(sys.argv) < 3:
            print("error: missing process name")
            print("usage: ./playground start-proc <name>")
            return 1
        return start_process(sys.argv[2])
    elif cmd == "stop-proc":
        if len(sys.argv) < 3:
            print("error: missing process name")
            print("usage: ./playground stop-proc <name>")
            return 1
        return stop_process(sys.argv[2])
    elif cmd == "restart-proc":
        if len(sys.argv) < 3:
            print("error: missing process name")
            print("usage: ./playground restart-proc <name>")
            return 1
        return restart_process(sys.argv[2])

    # orders
    elif cmd == "submit-order":
        return submit_order()
    elif cmd == "batch-orders":
        return batch_orders()
    elif cmd == "stress":
        try:
            rate = int(sys.argv[2]) if len(sys.argv) > 2 else 100
            dur = int(sys.argv[3]) if len(sys.argv) > 3 else 60
        except ValueError:
            print("error: rate and duration must be integers")
            print("usage: ./playground stress [rate] [duration]")
            return 1
        return stress_test(rate, dur)
    elif cmd == "maker":
        action = sys.argv[2] if len(sys.argv) > 2 else "start"
        return maker(action)

    # info
    elif cmd == "logs":
        follow = "--follow" in sys.argv or "-f" in sys.argv
        return logs_cmd(follow)
    elif cmd == "scenarios":
        return scenarios()
    elif cmd == "health":
        return health()
    elif cmd == "doctor":
        return doctor()

    # utils
    elif cmd == "reset":
        yes = "--yes" in sys.argv or "-y" in sys.argv
        return reset(yes=yes)

    else:
        print(f"unknown command: {cmd}")
        print(__doc__)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
