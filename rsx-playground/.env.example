# RSX playground env (copy to .env, fill in secrets)
PG_URL=postgres://rsx:secret@localhost:5432/rsx_dev

# rsx-auth (GitHub OAuth) — leave empty to disable auth
RSX_GW_JWT_SECRET=
RSX_AUTH_GITHUB_CLIENT_ID=
RSX_AUTH_GITHUB_CLIENT_SECRET=
RSX_AUTH_REDIRECT_URI=http://localhost:49171/oauth/github/callback
RSX_AUTH_TRADE_UI_URL=http://localhost:49171/trade/
RSX_AUTH_STARTER_COLLATERAL=10000000000

# Marketdata WS, gateway URLs (defaults usually fine)
# GATEWAY_URL=ws://localhost:8080
# GATEWAY_HTTP=http://localhost:8080
# MARKETDATA_WS=ws://localhost:8180
# AUTH_HTTP=http://localhost:8082
