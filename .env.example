# RSX dev environment
# Copy to .env, fill secrets, then `./rsx-playground/playground start`.

# ── Gateway / playground (required) ─────────────────────
# JWT secret used by rsx-gateway to validate tokens, and by
# the playground / market_maker / stress client to mint
# them. `./rsx-playground/playground start` injects the dev
# value `rsx-dev-secret-not-for-prod` if the operator
# hasn't set one; production MUST override with a real
# secret minted by rsx-auth and never use the dev value.
RSX_GW_JWT_SECRET=

# Postgres URL for risk write-behind, accounts, frozen_orders.
# Default expects role=rsx db=rsx pw=rsx on localhost:5432.
# Bootstrap a fresh Postgres with:
#   psql -U postgres -c "CREATE ROLE rsx WITH LOGIN PASSWORD 'rsx';"
#   psql -U postgres -c "CREATE DATABASE rsx OWNER rsx;"
# rsx-risk and rsx-auth apply their own migrations on first
# start; nothing else to run by hand.
PG_URL=postgres://rsx:rsx@127.0.0.1:5432/rsx

# ── rsx-auth (optional; leave empty to skip) ────────────
# Without these, the playground mints dev JWTs and the
# Trade UI runs as a guest — fine for local dev.
RSX_AUTH_GITHUB_CLIENT_ID=
RSX_AUTH_GITHUB_CLIENT_SECRET=
RSX_AUTH_REDIRECT_URI=http://localhost:49171/oauth/github/callback
RSX_AUTH_TRADE_UI_URL=http://localhost:49171/trade/
RSX_AUTH_STARTER_COLLATERAL=10000000000

# ── Process URLs (defaults usually fine) ────────────────
# GATEWAY_URL=ws://localhost:8080
# GATEWAY_HTTP=http://localhost:8080
# MARKETDATA_WS=ws://localhost:8180
# AUTH_HTTP=http://localhost:8082

# ── Dev-only flags (NEVER set in production) ────────────
# When set, loopback callers can spoof user identity via
# the x-user-id header. The server prints a WARN line on
# first use. Required for the Trade UI dot to turn green
# without a real auth flow.
# PLAYGROUND_ALLOW_INSECURE_USER_ID=1
