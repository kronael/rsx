# Gateway: WS ingress + casting/UDP to risk. On core 1 (hot path,
# io_uring). Binds loopback :8080 — nginx/caddy terminates TLS in
# front and proxies wss://rsx.krons.cx here. The JWT secret comes
# from a separate 0400 file, never from this unit or the main env.
[Unit]
Description=RSX gateway (WS ingress)
Documentation=file:///opt/rsx/specs/2/9-deploy.md
After=network-online.target rsx-risk@0.service
Wants=network-online.target
Requires=rsx-risk@0.service
PartOf=rsx.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=rsx
Group=rsx
WorkingDirectory=/srv/data/rsx
EnvironmentFile=/opt/rsx/env/gateway.env
EnvironmentFile=/opt/rsx/env/secret.env
ExecStart=/opt/rsx/bin/rsx-gateway
Restart=on-failure
RestartSec=1
CPUAffinity=1
Nice=-5
# Many concurrent client WS fds + io_uring registered buffers.
LimitNOFILE=1048576
LimitMEMLOCK=infinity
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/srv/data/rsx

[Install]
WantedBy=rsx.target
