# Gateway JWT signing secret — HMAC-SHA256, shared with the auth
# service that mints client tokens. Copy to secret.env, fill in a real
# value, and lock it down:
#
#   cp secret.env.example secret.env
#   openssl rand -hex 32   # paste as the value below
#   install -m 0400 -o rsx -g rsx secret.env /opt/rsx/env/secret.env
#
# NEVER commit the filled-in secret. deploy.sh will refuse to proceed
# if /opt/rsx/env/secret.env is missing or still holds this placeholder.
RSX_GW_JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
