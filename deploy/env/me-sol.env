# rsx-me@sol — matching engine, symbol SOL (id 3). core 5.
RSX_ME_SYMBOL_ID=3
RSX_ME_PRICE_DECIMALS=4
RSX_ME_QTY_DECIMALS=6
RSX_ME_TICK_SIZE=1
RSX_ME_LOT_SIZE=10000
RSX_ME_WAL_DIR=${PREFIX}/data/rsx/wal/sol
RSX_ME_CAST_ADDR=127.0.0.1:9103
RSX_RISK_CAST_ADDR=127.0.0.1:9200
RSX_MD_CAST_ADDR=127.0.0.1:9503
RSX_ME_REPLICATION_BIND_ADDR=127.0.0.1:9703
RSX_ME_DATABASE_URL=${DATABASE_URL}
RSX_ME_CORE_ID=5
RSX_ME_HEALTH_ADDR=127.0.0.1:9803
RUST_LOG=info
# Replication TLS (mandatory). deploy.sh provisions snakeoil certs
# into ${PREFIX}/data/rsx/certs; replace with real certs in prod.
RSX_REPL_CERT_PATH=${PREFIX}/data/rsx/certs/cert.pem
RSX_REPL_KEY_PATH=${PREFIX}/data/rsx/certs/key.pem
RSX_REPL_CA_PATH=${PREFIX}/data/rsx/certs/ca.pem
