# rsx-me@eth — matching engine, symbol ETH (id 2). core 4.
RSX_ME_SYMBOL_ID=2
RSX_ME_PRICE_DECIMALS=2
RSX_ME_QTY_DECIMALS=8
RSX_ME_TICK_SIZE=10
RSX_ME_LOT_SIZE=1000
RSX_ME_WAL_DIR=${PREFIX}/data/rsx/wal/eth
RSX_ME_CAST_ADDR=127.0.0.1:9102
RSX_RISK_CAST_ADDR=127.0.0.1:9200
RSX_MD_CAST_ADDR=127.0.0.1:9502
RSX_ME_REPLICATION_BIND_ADDR=127.0.0.1:9702
RSX_ME_DATABASE_URL=${DATABASE_URL}
RSX_ME_CORE_ID=4
RSX_ME_HEALTH_ADDR=127.0.0.1:9802
RUST_LOG=info
# Replication TLS (mandatory). deploy.sh provisions snakeoil certs
# into ${PREFIX}/data/rsx/certs; replace with real certs in prod.
RSX_REPL_CERT_PATH=${PREFIX}/data/rsx/certs/cert.pem
RSX_REPL_KEY_PATH=${PREFIX}/data/rsx/certs/key.pem
RSX_REPL_CA_PATH=${PREFIX}/data/rsx/certs/ca.pem
