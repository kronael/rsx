# rsx-mark — mark price aggregator. off-path, core 0 (unpinned).
RSX_MARK_LISTEN_ADDR=127.0.0.1:9400
RSX_MARK_WAL_DIR=${PREFIX}/data/rsx/wal/mark
RSX_MARK_STREAM_ID=100
RSX_MARK_SYMBOL_MAP=BTC=1,BTCUSDT=1,BTC-USD=1,ETH=2,ETHUSDT=2,ETH-USD=2,SOL=3,SOLUSDT=3,SOL-USD=3
RSX_RISK_MARK_CAST_ADDR=127.0.0.1:9600
RSX_MARK_SOURCE_BINANCE_ENABLED=1
RSX_MARK_SOURCE_BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=btcusdt@trade/ethusdt@trade/solusdt@trade
RSX_MARK_SOURCE_COINBASE_ENABLED=0
RSX_MARK_HEALTH_ADDR=127.0.0.1:9830
RUST_LOG=info
