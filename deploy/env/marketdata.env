# rsx-marketdata — public book/trades WS. core 6. Binds loopback;
# nginx fronts the public market-data WS. Replays ME stream 1 (BTC).
RSX_MD_LISTEN=127.0.0.1:8180
RSX_ME_CAST_ADDRS=127.0.0.1:9101,127.0.0.1:9102,127.0.0.1:9103
RSX_MD_STREAM_ID=1
RSX_MD_REPLAY_ADDR=127.0.0.1:9701
RSX_MD_CORE_ID=6
RSX_MD_HEALTH_ADDR=127.0.0.1:9840
RUST_LOG=info
# Replication TLS (mandatory). deploy.sh provisions snakeoil certs
# into ${PREFIX}/data/rsx/certs; replace with real certs in prod.
RSX_REPL_CERT_PATH=${PREFIX}/data/rsx/certs/cert.pem
RSX_REPL_KEY_PATH=${PREFIX}/data/rsx/certs/key.pem
RSX_REPL_CA_PATH=${PREFIX}/data/rsx/certs/ca.pem
