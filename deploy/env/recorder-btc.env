# rsx-recorder@btc — archive ME stream 1 (BTC). off-path, core 0.
# ARCHIVE_DIR is on the dedicated archive volume; RETAIN_DAYS keeps a
# rolling local window (the object-store offload is the permanent
# audit tier — see deploy/README.md and bugs.md RECORDER-ARCHIVE-DEV-DISK).
RSX_RECORDER_STREAM_ID=1
RSX_RECORDER_PRODUCER_ADDR=127.0.0.1:9701
RSX_RECORDER_ARCHIVE_DIR=${PREFIX}/data/rsx/archive
RSX_RECORDER_TIP_FILE=${PREFIX}/data/rsx/recorder-tip-1
RSX_RECORDER_RETAIN_DAYS=7
RSX_RECORDER_HEALTH_ADDR=127.0.0.1:9851
RUST_LOG=info
