# rsx-gateway — WS ingress. core 1. Binds loopback; nginx fronts it
# with TLS. RSX_GW_JWT_SECRET is NOT here — it lives in secret.env
# (mode 0400), loaded as a second EnvironmentFile by the unit.
RSX_GW_LISTEN=127.0.0.1:8080
RSX_GW_CAST_ADDR=127.0.0.1:9300
RSX_RISK_CAST_ADDR=127.0.0.1:9200
RSX_GW_WAL_DIR=${PREFIX}/data/rsx/wal
RSX_GW_RL_USER=10
RSX_GW_RL_IP=100
RSX_MAX_SYMBOLS=16
RSX_GW_CORE_ID=1
RSX_GW_HEALTH_ADDR=127.0.0.1:9820
RSX_SYMBOL_1_TICK_SIZE=50
RSX_SYMBOL_1_LOT_SIZE=100
RSX_SYMBOL_2_TICK_SIZE=10
RSX_SYMBOL_2_LOT_SIZE=1000
RSX_SYMBOL_3_TICK_SIZE=1
RSX_SYMBOL_3_LOT_SIZE=10000
RUST_LOG=info
